{
  "name": "jiyi-desktop-pet",
  "version": "0.1.0",
  "productName": "Desktop Pet",
  "description": "A minimal macOS-first desktop pet app built with Electron, React, and TypeScript.",
  "main": "dist/main/main.js",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5173 && tsc -p tsconfig.electron.json && electron .",
    "build": "npm run clean && tsc -p tsconfig.electron.json && vite build",
    "package:mac": "npm run build && electron-forge package --platform=darwin",
    "make:mac": "npm run build && electron-forge make --platform=darwin",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "desktop-pet"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "electron": "^37.10.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "wait-on": "^8.0.5"
  }
}
